# SecondPage.ai Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=secondpage
MYSQL_USER=secondpage_user
MYSQL_PASSWORD=your_secure_password

# Application Configuration
APP_PORT=3000
APP_BIND=127.0.0.1
SEARCH_PROVIDER=http

# Application Branding
VITE_APP_ID=secondpage-ai
VITE_APP_TITLE=secondpage.ai - intelligent agent search beyond SEO
VITE_APP_LOGO=

# REST API Key (required for /api-v1 endpoints)
API_KEY=your_api_key_here

# Search Provider Options:
# - http: Real search results from Google, Bing, DuckDuckGo, Brave (default)
# - llm: AI-generated search results for testing

# Brave Search API (optional, free tier: 2000 queries/month)
# Get your key at https://api.search.brave.com/
BRAVE_API_KEY=

# Google Custom Search API (optional, free tier: 100 queries/day)
# 1. Get API key at https://console.cloud.google.com/apis/credentials
# 2. Create a Custom Search Engine at https://programmablesearchengine.google.com/
#    - Set "Search the entire web" to ON
# 3. Copy the Search Engine ID (cx value)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Canonical hostname for redirects (optional, used in production)
# When set, requests to other hostnames (www, apprunner URL) redirect here
CANONICAL_HOST=
